# Event Bridge Frontend - Environment Variables
# Copy this to .env.local for local dev (leave VITE_API_BASE_URL empty)
# Set VITE_API_BASE_URL on Vercel to your Render backend URL

# Backend URL (leave empty for local dev - Vite proxy handles it)
# For production on Vercel, set this to your Render backend URL:
# VITE_API_BASE_URL=https://event-bridge-backend.onrender.com
VITE_API_BASE_URL=
